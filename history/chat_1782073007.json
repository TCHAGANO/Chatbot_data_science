            "query_sql": "WITH chiffre_affaires_sexe AS ( SELECT sexe_client, SUM(v.montant_ventes) AS total_ca FROM ventes v JOIN commandes cmd ON v.id_commande = cmd.id_commande JOIN clients c ON cmd.id_client = c.id_client GROUP BY sexe_client ) SELECT sexe_client, total_ca, (total_ca - (SELECT MIN(total_ca) FROM chiffre_affaires_sexe)) / (SELECT MIN(total_ca) FROM chiffre_affaires_sexe) * 100 AS ecart_pourcentage FROM chiffre_affaires_sexe ORDER BY total_ca DESC LIMIT 1",
